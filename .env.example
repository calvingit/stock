# Stock Platform Environment Variables
# Copy to .env and fill in your values

# Wind AIFin Market API Key
WIND_API_KEY=your_wind_api_key_here

# Wind MCP Skill directory (for CLI data fetching)
WIND_CLI_DIR=~/.hermes/skills/wind-mcp-skill

# Cache directory for ETF backtest data
ETF_CACHE_DIR=/tmp/etf_backtest_cache
